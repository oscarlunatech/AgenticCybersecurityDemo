#!/bin/bash
set -euxo pipefail
export DEBIAN_FRONTEND=noninteractive

# ===========================================================================
# Wazuh all-in-one (manager + indexer + dashboard) — Phase 6 monitoring box
# ---------------------------------------------------------------------------
# The Wazuh install is BEST-EFFORT (set +e): a failure must never abort
# cloud-init and leave the box with no Caddy (the connection-refused we hit).
# Caddy is installed UNCONDITIONALLY afterwards so the vhost + cert come up
# regardless; if the dashboard isn't ready it 502s (debuggable) rather than
# refusing. is_dev selects the Lets Encrypt STAGING CA so dev rebuilds freely.
# ===========================================================================

apt-get update
apt-get install -y ca-certificates curl gnupg debian-keyring debian-archive-keyring apt-transport-https

# Swap cushion: t3.medium is 4 GB (Wazuh's documented minimum); OpenSearch wants
# headroom, so add 2 GB of swap to avoid OOM during indexing.
if [ ! -f /swapfile ]; then
  fallocate -l 2G /swapfile
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  echo '/swapfile none swap sw 0 0' >> /etc/fstab
fi

# ---------------------------------------------------------------------------
# 1) Wazuh all-in-one. The install assistant is VERSION-PINNED: the /4.x/ path
#    does NOT host the script (it returns an S3 XML error, which previously got
#    saved and "executed", aborting boot). Download robustly (-f fail on HTTP
#    error so we never save an error body, -L follow redirects, -S show errors)
#    and validate it's a shell script before running. -a all-in-one, -i ignore
#    the hardware check (t3.medium is borderline). All best-effort.
# ---------------------------------------------------------------------------
set +e
WAZUH_VERSION="4.14"
curl -fsSL -o /root/wazuh-install.sh "https://packages.wazuh.com/$WAZUH_VERSION/wazuh-install.sh"
if head -n1 /root/wazuh-install.sh | grep -q '^#!'; then
  bash /root/wazuh-install.sh -a -i || echo "WARN: wazuh-install.sh exited non-zero"

  # Move the dashboard off 443 so Caddy can own it (the yml exists only post-install).
  sed -i 's/^server.host:.*/server.host: 127.0.0.1/' /etc/wazuh-dashboard/opensearch_dashboards.yml || true
  sed -i 's/^server.port:.*/server.port: 5601/'      /etc/wazuh-dashboard/opensearch_dashboards.yml || true
  systemctl restart wazuh-dashboard || true

  # Rotate the installer's default admin password to ours. set +x keeps the
  # secret out of the cloud-init log. NOTE: a single-quote in the password would
  # break the quoted assignment (same caveat as the Bedrock key) — avoid one.
  set +x
  WAZUH_PW='${admin_password}'
  PWTOOL="$(command -v wazuh-passwords-tool.sh || echo /usr/share/wazuh-indexer/plugins/opensearch-security/tools/wazuh-passwords-tool.sh)"
  if [ -x "$PWTOOL" ]; then
    "$PWTOOL" -u admin -p "$WAZUH_PW" || echo "WARN: admin password rotation failed; rotate manually"
  else
    echo "WARN: wazuh-passwords-tool not found; rotate the admin password manually"
  fi
  set -x
else
  echo "WARN: downloaded wazuh-install.sh is not a script (got non-shebang content); skipping Wazuh install"
fi
set -e

# ---------------------------------------------------------------------------
# 2) Grafana (public read-only stats) — runs as a HARDENED Docker container so a
#    Grafana CVE is CONTAINED, not a host process sitting next to the SIEM. Same
#    hardening the lab containers use: drop all caps, no-new-privileges, read-only
#    rootfs (+ a tmpfs and a data volume for the writable paths). Bound to
#    127.0.0.1 only — this box's Caddy terminates TLS for ${stats_host} in front.
#    Anonymous access is Viewer-only and Explore is disabled, so visitors view the
#    curated dashboards but cannot run ad-hoc queries against any datasource.
#    Best-effort so a Grafana hiccup can't abort the rest of the boot.
# ---------------------------------------------------------------------------
set +e
curl -fsSL https://get.docker.com | sh
GRAFANA_IMAGE="grafana/grafana:11.4.0" # pinned for reproducibility
docker pull "$GRAFANA_IMAGE" || echo "WARN: grafana image pull failed"
docker volume create grafana-data >/dev/null 2>&1
docker rm -f grafana >/dev/null 2>&1

# Provision the datasource + a starter dashboard as code (mounted read-only). The
# datasource is the Infinity plugin in PROXY mode, so Grafana's backend (not the
# visitor's browser) fetches https://${lab_host}/api/stats — that endpoint is public
# but exposes only aggregate counts. Anonymous is Viewer + Explore-disabled, so a
# visitor can't repoint the datasource or run ad-hoc queries.
mkdir -p /etc/grafana-provisioning/datasources /etc/grafana-provisioning/dashboards
cat > /etc/grafana-provisioning/datasources/lab-stats.yaml <<'DS_EOF'
apiVersion: 1
datasources:
  - name: lab-stats
    uid: lab-stats
    type: yesoreyeram-infinity-datasource
    access: proxy
    isDefault: true
    editable: false
    jsonData:
      tlsSkipVerify: ${lab_tls_skip}
DS_EOF

# --- Scoped read-only OpenSearch user for Grafana (curated security stats) ------
# A dedicated user that can ONLY READ the Wazuh alert indices — never admin, never
# write, never any other index. Its password is GENERATED here and NEVER leaves the
# box (not in Terraform/state): used to create the user and to write Grafana's
# datasource config, both on this host. All under set +x so it stays out of the log.
set +x
WAZUH_PW='${admin_password}'
GRAFANA_RO_PW="$(openssl rand -base64 24 | tr -dc 'A-Za-z0-9')Ab1." # complexity + shell-safe
for i in $(seq 1 30); do
  curl -sk -u "admin:$WAZUH_PW" https://127.0.0.1:9200/_plugins/_security/health >/dev/null 2>&1 && break
  sleep 3
done
curl -sk -u "admin:$WAZUH_PW" -X PUT https://127.0.0.1:9200/_plugins/_security/api/roles/grafana_ro \
  -H 'Content-Type: application/json' \
  -d '{"cluster_permissions":["cluster_monitor","cluster_composite_ops_ro"],"index_permissions":[{"index_patterns":["wazuh-alerts-*","wazuh-monitoring-*"],"allowed_actions":["read","indices:admin/mappings/get","indices:admin/mappings/fields/get*"]}]}' \
  >/dev/null 2>&1 || echo "WARN: grafana_ro role create failed"
curl -sk -u "admin:$WAZUH_PW" -X PUT https://127.0.0.1:9200/_plugins/_security/api/internalusers/grafana_ro \
  -H 'Content-Type: application/json' \
  -d "{\"password\":\"$GRAFANA_RO_PW\",\"opendistro_security_roles\":[\"grafana_ro\"]}" \
  >/dev/null 2>&1 || echo "WARN: grafana_ro user create failed"

# --- 90-day retention on Wazuh ALERT indices (privacy / data minimization) -----
# Deletes wazuh-alerts-* indices older than 90 days — the IP-bearing security EVENT
# stream only. The vulnerability inventory (wazuh-states-*), SCA/CIS, and agent
# inventory are current-state indices and are deliberately left intact. The
# ism_template auto-applies the policy to each new daily index; we also attach it to
# any existing alert indices. Best-effort.
curl -sk -u "admin:$WAZUH_PW" -X PUT https://127.0.0.1:9200/_plugins/_ism/policies/wazuh_alerts_retention \
  -H 'Content-Type: application/json' \
  -d '{"policy":{"description":"Delete wazuh-alerts indices after 90 days (privacy retention).","default_state":"hot","states":[{"name":"hot","actions":[],"transitions":[{"state_name":"delete","conditions":{"min_index_age":"90d"}}]},{"name":"delete","actions":[{"delete":{}}],"transitions":[]}],"ism_template":[{"index_patterns":["wazuh-alerts-*"],"priority":100}]}}' \
  >/dev/null 2>&1 || echo "WARN: ISM retention policy create failed"
curl -sk -u "admin:$WAZUH_PW" -X POST 'https://127.0.0.1:9200/_plugins/_ism/add/wazuh-alerts-*' \
  -H 'Content-Type: application/json' -d '{"policy_id":"wazuh_alerts_retention"}' \
  >/dev/null 2>&1 || echo "WARN: ISM retention attach failed"

# OpenSearch datasource bound to that scoped user. Local self-signed indexer cert,
# so tlsSkipVerify (it's 127.0.0.1 on this box). Password injected from the shell
# var — note the UNQUOTED heredoc so $GRAFANA_RO_PW expands.
cat > /etc/grafana-provisioning/datasources/wazuh-alerts.yaml <<OS_EOF
apiVersion: 1
datasources:
  - name: wazuh-alerts
    uid: wazuh-alerts
    type: grafana-opensearch-datasource
    access: proxy
    url: https://127.0.0.1:9200
    basicAuth: true
    basicAuthUser: grafana_ro
    editable: false
    jsonData:
      tlsSkipVerify: true
      database: "wazuh-alerts-*"
      timeField: timestamp
      flavor: opensearch
      version: 2.19.0
      pplEnabled: false
    secureJsonData:
      basicAuthPassword: "$GRAFANA_RO_PW"
OS_EOF
set -x

cat > /etc/grafana-provisioning/dashboards/provider.yaml <<'PROV_EOF'
apiVersion: 1
providers:
  - name: lab
    type: file
    disableDeletion: false
    allowUiUpdates: true
    options:
      path: /etc/grafana/provisioning/dashboards
PROV_EOF
cat > /etc/grafana-provisioning/dashboards/lab-stats.json <<'DASH_EOF'
{
  "uid": "lab-stats",
  "title": "Lab — Public Stats",
  "tags": ["lab"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    { "id": 1, "type": "stat", "title": "Active sessions",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" },
      "targets": [ { "refId": "A", "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" }, "type": "json", "source": "url", "parser": "backend", "format": "table", "url": "https://${lab_host}/api/stats", "url_options": { "method": "GET" }, "root_selector": "", "columns": [ { "selector": "activeSessions", "text": "value", "type": "number" } ] } ] },
    { "id": 2, "type": "stat", "title": "Sessions started (since boot)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" },
      "targets": [ { "refId": "A", "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" }, "type": "json", "source": "url", "parser": "backend", "format": "table", "url": "https://${lab_host}/api/stats", "url_options": { "method": "GET" }, "root_selector": "", "columns": [ { "selector": "sessionsStartedTotal", "text": "value", "type": "number" } ] } ] },
    { "id": 3, "type": "stat", "title": "Challenges solved (since boot)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" },
      "targets": [ { "refId": "A", "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" }, "type": "json", "source": "url", "parser": "backend", "format": "table", "url": "https://${lab_host}/api/stats", "url_options": { "method": "GET" }, "root_selector": "", "columns": [ { "selector": "challengesSolvedTotal", "text": "value", "type": "number" } ] } ] },
    { "id": 4, "type": "stat", "title": "Uptime",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" },
      "targets": [ { "refId": "A", "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" }, "type": "json", "source": "url", "parser": "backend", "format": "table", "url": "https://${lab_host}/api/stats", "url_options": { "method": "GET" }, "root_selector": "", "columns": [ { "selector": "uptimeSeconds", "text": "value", "type": "number" } ] } ] },
    { "id": 5, "type": "table", "title": "By challenge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" },
      "targets": [ { "refId": "A", "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "lab-stats" }, "type": "json", "source": "url", "parser": "backend", "format": "table", "url": "https://${lab_host}/api/stats", "url_options": { "method": "GET" }, "root_selector": "byChallenge", "columns": [ { "selector": "name", "text": "Challenge", "type": "string" }, { "selector": "started", "text": "Started", "type": "number" }, { "selector": "solved", "text": "Solved", "type": "number" } ] } ] }
  ]
}
DASH_EOF
cat > /etc/grafana-provisioning/dashboards/lab-security.json <<'SEC_EOF'
{
  "uid": "lab-security",
  "title": "Lab — Security Activity",
  "tags": ["lab"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    { "id": 1, "type": "timeseries", "title": "Security events over time",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh-alerts" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-opensearch-datasource", "uid": "wazuh-alerts" }, "query": "", "metrics": [ { "id": "1", "type": "count" } ], "bucketAggs": [ { "id": "2", "type": "date_histogram", "field": "timestamp", "settings": { "interval": "auto" } } ], "timeField": "timestamp" } ] }
  ]
}
SEC_EOF

# The Wazuh indexer listens on 127.0.0.1:9200 ONLY, so a bridged container can't
# reach it (the container's own loopback != the host's). Use the host network
# namespace; GF_SERVER_HTTP_ADDR keeps Grafana itself bound to localhost so only
# Caddy fronts it. (Other hardening — caps/no-new-privs/read-only — is unaffected.)
set +x # keep the admin password out of the cloud-init log
docker run -d --name grafana --restart unless-stopped \
  --network host \
  -e GF_SERVER_HTTP_ADDR=127.0.0.1 \
  --cap-drop ALL \
  --security-opt no-new-privileges \
  --read-only \
  --tmpfs /tmp \
  -v grafana-data:/var/lib/grafana \
  -v /etc/grafana-provisioning:/etc/grafana/provisioning:ro \
  -e GF_INSTALL_PLUGINS=yesoreyeram-infinity-datasource,grafana-opensearch-datasource \
  -e GF_SECURITY_ADMIN_PASSWORD='${grafana_admin_pass}' \
  -e GF_USERS_ALLOW_SIGN_UP=false \
  -e GF_AUTH_ANONYMOUS_ENABLED=true \
  -e GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer \
  -e GF_EXPLORE_ENABLED=false \
  -e GF_SERVER_ROOT_URL=https://${stats_host} \
  "$GRAFANA_IMAGE" \
  || echo "WARN: grafana container failed to start"
set -x
set -e

# ---------------------------------------------------------------------------
# 3) Caddy in front of both web UIs — installed regardless of the above so the
#    public vhosts + TLS come up. Terminates TLS for ${monitoring_host} (the Wazuh
#    dashboard, behind basic_auth) and ${stats_host} (Grafana, public read-only).
#    The bcrypt hash for the dashboard gate is generated at boot from the admin
#    password; split it into its own secret if you want distinct creds.
# ---------------------------------------------------------------------------
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
  | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
  | tee /etc/apt/sources.list.d/caddy-stable.list
apt-get update
apt-get install -y caddy

set +x
WAZUH_PW='${admin_password}'
BASIC_HASH="$(HOME=/root caddy hash-password --plaintext "$WAZUH_PW")"
set -x

cat > /etc/caddy/Caddyfile <<CADDY_EOF
%{ if is_dev ~}
{
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}
%{ endif ~}
${monitoring_host} {
    # No encode-gzip directive here: the Wazuh dashboard compresses its own assets,
    # and a second encoding layer in Caddy collides with the upstream Content-Encoding
    # and corrupts the JS bundles (browser receives ~9-byte empty bodies, so the
    # securityDashboards plugin never initializes). Pass the upstream's encoding
    # through untouched.
    basic_auth {
        monitor $BASIC_HASH
    }
    reverse_proxy https://127.0.0.1:5601 {
        header_up -Authorization
        transport http {
            tls_insecure_skip_verify
        }
    }
}
${stats_host} {
    # Public, anonymous, read-only Grafana. No basic_auth — anyone can view the
    # curated stats. Grafana itself enforces Viewer-only + Explore disabled.
    reverse_proxy 127.0.0.1:3000
}
CADDY_EOF

systemctl enable caddy
systemctl restart caddy
