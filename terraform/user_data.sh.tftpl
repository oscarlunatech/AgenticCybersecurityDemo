#!/bin/bash
set -euxo pipefail

# --- Install Caddy (handles Let's Encrypt certs automatically) -------------
apt-get update
apt-get install -y debian-keyring debian-archive-keyring apt-transport-https curl gpg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
  | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
  | tee /etc/apt/sources.list.d/caddy-stable.list
apt-get update
apt-get install -y caddy

# --- Site content -----------------------------------------------------------
mkdir -p /var/www/html
echo "${site_b64}" | base64 -d > /var/www/html/index.html
chown -R caddy:caddy /var/www/html

# --- Caddy config -----------------------------------------------------------
# Caddy obtains and auto-renews a Let's Encrypt cert for these names. www
# permanently redirects to the apex so you have one canonical URL.
cat > /etc/caddy/Caddyfile <<'CADDYEOF'
${domain} {
    root * /var/www/html
    file_server
    encode gzip
}

${www} {
    redir https://${domain}{uri} permanent
}
CADDYEOF

systemctl enable caddy
systemctl restart caddy
