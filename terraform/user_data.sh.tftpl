#!/bin/bash
set -euxo pipefail
export DEBIAN_FRONTEND=noninteractive

# ===========================================================================
# Base packages: Docker, Node.js, Caddy
# ===========================================================================
apt-get update
apt-get install -y ca-certificates curl gnupg debian-keyring debian-archive-keyring apt-transport-https unzip

# AWS CLI v2 (Ubuntu 24.04 no longer ships an `awscli` apt package). Used at boot
# to fetch the web artifacts from S3.
curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o /tmp/awscliv2.zip
unzip -q /tmp/awscliv2.zip -d /tmp
/tmp/aws/install
rm -rf /tmp/aws /tmp/awscliv2.zip

# Docker
curl -fsSL https://get.docker.com | sh
usermod -aG docker ubuntu

# Node.js 20
curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
apt-get install -y nodejs

# Caddy
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
  | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
  | tee /etc/apt/sources.list.d/caddy-stable.list
apt-get update
apt-get install -y caddy

# ===========================================================================
# Web content (landing page + lab control page)
# Fetched from the artifacts bucket rather than inlined: user_data is gzip-bounded
# to 16 KB and these files are large. A READ-ONLY key (s3:GetObject on this bucket
# only) is used for the fetch and not persisted. The content hashes
# (${site_index_hash} ${lab_html_hash}) are embedded so editing a file re-renders
# user_data, which rebuilds the box and re-fetches.
# ===========================================================================
mkdir -p /var/www/html
set +x  # keep the read-only key out of the cloud-init log
export AWS_ACCESS_KEY_ID="${ro_key_id}"
export AWS_SECRET_ACCESS_KEY="${ro_key_secret}"
export AWS_DEFAULT_REGION="${aws_region}"
set -x
aws s3 cp "s3://${artifacts_bucket}/index.html" /var/www/html/index.html
aws s3 cp "s3://${artifacts_bucket}/lab.html"   /var/www/html/lab.html
set +x
unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_DEFAULT_REGION
set -x
chown -R caddy:caddy /var/www/html

# ===========================================================================
# Caddy config: static site + reverse proxy to the orchestrator
# (built in Terraform: prod uses the real CA + www redirect; dev uses staging CA)
# ===========================================================================
cat > /etc/caddy/Caddyfile <<'CADDY_EOF'
${caddyfile}
CADDY_EOF
systemctl enable caddy
systemctl restart caddy

# ===========================================================================
# Vulnerable training targets (pulled, not built)
# The host has egress and pulls here at boot; per-session containers run on an
# internal (no-egress) network, so every challenge image must already be present
# locally. Pull each distinct image referenced by the challenge registry
# (lab/orchestrator/challenges.js). The current challenges all use Juice Shop.
# ===========================================================================
docker pull bkimminich/juice-shop:latest

# Custom SQL-injection target (Phase 5), BUILT on the box like the client image
# (so it exists locally before any no-egress session needs it). Its small build
# context lives in the artifacts bucket — kept out of user_data's 16 KB cap — and
# is fetched with the same read-only key. The content hash ${sqli_target_hash}
# is embedded so editing any target file re-renders user_data and rebuilds the box.
#
# Best-effort (`set +e`): a failure here must NOT abort cloud-init and take the
# orchestrator down with it — the Juice Shop challenges would still work, and only
# the SQLi challenge would be unavailable. The read-only key has s3:GetObject but
# NOT s3:ListBucket, so fetch each file BY KEY (never `aws s3 cp --recursive`,
# which needs ListBucket and would fail AccessDenied).
set +e
mkdir -p /opt/sqli-login
set +x  # keep the read-only key out of the cloud-init log
export AWS_ACCESS_KEY_ID="${ro_key_id}"
export AWS_SECRET_ACCESS_KEY="${ro_key_secret}"
export AWS_DEFAULT_REGION="${aws_region}"
set -x
for f in Dockerfile server.js query.vulnerable.js query.fixed.js; do
  aws s3 cp "s3://${artifacts_bucket}/sqli-login/$f" "/opt/sqli-login/$f"
done
set +x
unset AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_DEFAULT_REGION
set -x
docker build -t lab-sqli-login:latest /opt/sqli-login \
  || echo "WARN: sqli-login target build failed; the SQLi challenge will be unavailable"
set -e

# ===========================================================================
# Client (attacker) image
# ===========================================================================
mkdir -p /opt/client-image
cat > /opt/client-image/Dockerfile <<'CLIENT_DOCKERFILE_EOF'
${client_dockerfile}
CLIENT_DOCKERFILE_EOF
docker build -t lab-client:latest /opt/client-image


# ===========================================================================
# Orchestrator service
# ===========================================================================
mkdir -p /opt/demo-orchestrator
cat > /opt/demo-orchestrator/package.json <<'PKG_EOF'
${pkg_json}
PKG_EOF
cat > /opt/demo-orchestrator/server.js <<'SERVER_EOF'
${server_js}
SERVER_EOF
cat > /opt/demo-orchestrator/challenges.js <<'CHALLENGES_EOF'
${challenges_js}
CHALLENGES_EOF
cat > /opt/demo-orchestrator/agent.js <<'AGENT_EOF'
${agent_js}
AGENT_EOF
chown -R ubuntu:ubuntu /opt/demo-orchestrator
cd /opt/demo-orchestrator && sudo -u ubuntu npm install --omit=dev

# Guidance agent secret (Phase 4): the Bedrock API key the orchestrator uses to
# call Gemma 4. Written to a 0600 EnvironmentFile (referenced by the systemd unit)
# rather than the committed unit file. Wrapped in set +x so the key never lands in
# the cloud-init log; the quoted heredoc avoids any shell expansion of the value.
# Empty key => the file is harmless and guidance stays disabled.
set +x
install -o ubuntu -g ubuntu -m 600 /dev/null /etc/demo-orchestrator.env
cat > /etc/demo-orchestrator.env <<'ENV_EOF'
BEDROCK_API_KEY=${bedrock_api_key}
ENV_EOF
set -x

cat > /etc/systemd/system/demo-orchestrator.service <<'SVC_EOF'
${svc_file}
SVC_EOF
systemctl daemon-reload
systemctl enable --now demo-orchestrator
