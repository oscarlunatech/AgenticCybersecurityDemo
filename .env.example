# Copy to ".env" and fill in real values. NEVER commit .env.
# Then run:  source .env   before terraform.
export AWS_ACCESS_KEY_ID="your-access-key-id"
export AWS_SECRET_ACCESS_KEY="your-secret-access-key"
export AWS_DEFAULT_REGION="us-west-2"
export TF_VAR_artifacts_ro_access_key_id="your-access-key-id"
export TF_VAR_artifacts_ro_secret_access_key="your-secret-access-key"
export TF_VAR_bedrock_api_key="your-access-api-key" 
export TF_VAR_wazuh_admin_password="your-admin password"
export TF_VAR_grafana_admin_password="your-grafana-password"